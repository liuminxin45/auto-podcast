{
  "id": "auto-podcast-custom-sources",
  "version": "1.0.0",
  "description": "Auto-Podcast custom NewsNow source overlay.",
  "files": [
    {
      "source": "server/sources/autopodcast.ts",
      "target": "server/sources/autopodcast.ts",
      "overwrite": true
    }
  ],
  "text_patches": [
    {
      "id": "autopodcast-pre-source",
      "target": "shared/pre-sources.ts",
      "marker": "export const originSources = {",
      "position": "after",
      "insert_lines": [
        "  \"autopodcast\": {",
        "    name: \"Auto-Podcast\",",
        "    title: \"Custom RSS\",",
        "    type: \"realtime\",",
        "    column: \"tech\",",
        "    color: \"slate\",",
        "    interval: Time.Fast,",
        "    home: \"https://github.com/liuminxin45/auto-podcast\",",
        "  },"
      ]
    },
    {
      "id": "autopodcast-glob-types",
      "target": "server/glob.d.ts",
      "marker": "  export const _36kr: typeof import('./sources/_36kr')",
      "position": "after",
      "insert_lines": [
        "  export const autopodcast: typeof import('./sources/autopodcast')"
      ]
    }
  ]
}
